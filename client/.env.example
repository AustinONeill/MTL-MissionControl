# MTL Mission Control — Client Environment Variables
# Copy to .env.local and fill in values

# Base URL of the deployed Hono Worker API
VITE_API_BASE_URL=http://localhost:8787

# Stack Auth project ID (public — safe to expose)
VITE_STACK_PROJECT_ID=your_stack_project_id

# Cloudflare R2 CDN base URL for photo thumbnails
VITE_R2_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev
