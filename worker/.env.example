# MTL Mission Control — Worker Secrets
# Set via: wrangler secret put <NAME>
# DO NOT commit actual values

DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

STACK_AUTH_JWKS_URL=https://api.stack-auth.com/api/v1/projects/YOUR_PROJECT_ID/.well-known/jwks.json
STACK_AUTH_PROJECT_ID=your_stack_project_id

R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=mtl-photos
R2_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev

TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/xxx
BOT_FRAMEWORK_APP_ID=your_bot_app_id
BOT_FRAMEWORK_APP_SECRET=your_bot_app_secret

AZURE_AD_CLIENT_ID=your_azure_client_id
AZURE_AD_CLIENT_SECRET=your_azure_client_secret
AZURE_AD_TENANT_ID=your_azure_tenant_id
